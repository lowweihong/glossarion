# Glossarion — Environment Variables
# Copy this file to .env.local and fill in your values

# ── LLM (required for entity extraction) ──────────────────────────────────────
# Groq API key for llama-3.3-70b-versatile (current default)
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API key (optional — if switching extractor to Claude claude-sonnet-4-6)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Neo4j (optional — app works without this, using in-memory state) ───────────
# Aura free tier: https://neo4j.com/cloud/platform/aura-graph-database/
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ── Week 2 (Tavily web search expansion) ──────────────────────────────────────
# Get your key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── Week 3 (Clerk auth) ────────────────────────────────────────────────────────
# Get your keys at https://clerk.com → Create application
# After adding keys, install the SDK (pnpm add @clerk/nextjs) then replace
# middleware.ts with the Clerk snippet documented at the top of that file.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Week 3 (Supabase — graph persistence) ─────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Run the CREATE TABLE schema from lib/supabase.ts (top comment) in the SQL editor
# 3. Copy the URL + anon key from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
